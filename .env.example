# Copy to `.env.local` (dev) or set as deploy-host environment variables
# (production). All VITE_-prefixed variables are inlined into the client
# bundle at build time and are therefore PUBLIC — never put secrets here.

# --- Sentry (#33) ----------------------------------------------------------
# Without VITE_SENTRY_DSN, src/lib/sentry.js short-circuits and the
# @sentry/react bundle is never fetched. Drop a DSN in to flip it on.
# VITE_SENTRY_DSN=https://...@o0.ingest.sentry.io/0

# --- Sentry sourcemap upload (build-time only, NOT bundled) ---------------
# Set these at the deploy host so production builds upload sourcemaps.
# Without SENTRY_AUTH_TOKEN, the Vite plugin is skipped.
# SENTRY_ORG=ungebaut
# SENTRY_PROJECT=ungebaut-web
# SENTRY_AUTH_TOKEN=  # generate at sentry.io/orgredirect/organizations/:org/settings/auth-tokens/
